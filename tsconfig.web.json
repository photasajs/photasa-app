{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/renderer/src/**/*.ts",
        "src/renderer/src/**/*.d.ts",
        "src/preload/**/*.ts",
        "src/preload/**/*.d.ts",
        "src/common/**/*.ts",
        "src/common/**/*.d.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/renderer/src/*"],
            "@renderer/*": ["./src/renderer/src/*"],
            "@common/*": ["./src/common/*"],
            "@preload/*": ["./src/preload/*"]
        },
        "types": ["vitest/globals", "node", "@vue/test-utils"]
    }
}
