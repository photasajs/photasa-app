{
    "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
    "include": [
        "src/renderer/src/**/*.ts",
        "src/renderer/src/**/*.tsx",
        "src/renderer/src/**/*.d.ts",
        "src/renderer/src/**/*.vue",
        "src/common/**/*.ts",
        "src/common/**/*.d.ts"
    ],
    "compilerOptions": {
        "composite": true,
        "baseUrl": ".",
        "jsx": "preserve",
        "jsxFactory": "h",
        "jsxFragmentFactory": "Fragment",
        "types": [
            "vitest/globals",
            "node",
            "@vue/test-utils",
            "@vue/runtime-dom"
        ],
        "typeRoots": [
            "./src/renderer/src/types",
            "./node_modules/@types"
        ],
        "paths": {
            "@/*": ["./src/renderer/src/*"],
            "@renderer/*": ["./src/renderer/src/*"],
            "@common/*": ["./src/common/*"],
            "@preload/*": ["./src/preload/*"]
        }
    }
}
