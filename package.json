{
    "name": "picasa-vue-monorepo",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "nx run-many -t build",
        "test": "nx run-many -t test",
        "lint": "nx run-many -t lint",
        "typecheck": "nx run-many -t typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "prepare": "husky",
        "validate": "pnpm --filter @photasa/desktop run validate",
        "dev:desktop": "pnpm --filter @photasa/desktop dev",
        "build:desktop": "pnpm --filter @photasa/desktop build",
        "test:desktop": "pnpm --filter @photasa/desktop test",
        "typecheck:desktop": "pnpm --filter @photasa/desktop typecheck",
        "workflow:validate": "pnpm --filter @photasa/desktop run workflow:validate"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "husky": "^9.1.7",
        "nx": "^22.3.3",
        "prettier": "^3.2.5",
        "typescript": "^7.0.2"
    },
    "packageManager": "pnpm@9.0.0"
}
