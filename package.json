{
    "name": "picasa-vue-monorepo",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "prepare": "husky",
        "validate": "pnpm --filter @photasa/desktop run validate",
        "dev:desktop": "pnpm --filter @photasa/desktop dev",
        "build:desktop": "pnpm --filter @photasa/desktop build",
        "dev:photasa": "pnpm --filter @photasa/photasa dev",
        "dev:photasa:web": "pnpm --filter @photasa/photasa run dev:web",
        "build:photasa": "pnpm --filter @photasa/photasa build",
        "tauri:dev": "pnpm --filter @photasa/photasa dev",
        "tauri:build": "pnpm --filter @photasa/photasa run tauri:build",
        "clippy": "pnpm --filter @photasa/photasa run clippy",
        "test:desktop": "pnpm --filter @photasa/desktop test",
        "typecheck:desktop": "pnpm --filter @photasa/desktop typecheck",
        "workflow:validate": "pnpm --filter @photasa/desktop run workflow:validate"
    },
    "devDependencies": {
        "@systembug/pangu": "^0.0.12",
        "eslint": "^8.57.0",
        "husky": "^9.1.7",
        "turbo": "^2.3.0",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3"
    },
    "packageManager": "pnpm@9.0.0"
}
