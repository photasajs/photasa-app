    "node": "16.17.0",
    "yarn": "1.22.19"
  },
  "dependencies": {
    "log4js": "^6.7.1",
    "node-fetch": "^3.3.0",
    "object-assign": "^4.1.1",
    "querystring": "^0.2.1",
    "realm": "^11.3.2",
    "sharp": "^0.31.3",
    "url": "^0.11.0"
  }
