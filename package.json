{
    "name": "photasa",
    "productName": "Photasa",
    "version": "1.0.0",
    "description": "Another picasa like photo manager",
    "main": "./out/main/index.js",
    "author": "Albert Li <albert_lee@hotmail.com>",
    "homepage": "https://www.thepicasa.com",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "npm run typecheck:node && npm run typecheck:web",
        "start": "electron-vite preview",
        "dev": "electron-vite dev",
        "build": "npm run typecheck && electron-vite build",
        "postinstall": "electron-builder install-app-deps",
        "build:win": "npm run build && npm run sharp:win && electron-builder --win --config",
        "build:mac": "npm run build && electron-builder --mac --config",
        "build:linux": "npm run build && electron-builder --linux --config",
        "sharp:mac": "del-cli ./node_modules/sharp && npm install --platform=darwin --arch=arm64 sharp && npm rebuild --platform=darwin --arch=x64 sharp",
        "sharp:win": "del-cli ./node_modules/sharp && npm install --platform=win32 --arch=x64 sharp",
        "sharp:linux": "del-cli ./node_modules/sharp && npm install --platform=linux --arch=x64 sharp",
        "test": "jest --config jest.config.js",
        "coverage": "jest --config jest.config.js --coverage"
    },
    "dependencies": {
        "@babel/core": "7.21.8",
        "@bugsnag/electron": "^7.20.2",
        "@bugsnag/js": "7.20.2",
        "@bugsnag/plugin-vue": "7.19.0",
        "@electron-toolkit/preload": "1.0.3",
        "@electron-toolkit/utils": "1.0.2",
        "chokidar": "3.5.3",
        "comlink": "^4.4.1",
        "concurrent-tasks": "^1.0.7",
        "electron": "^30.0.0",
        "electron-is-dev": "^2.0.0",
        "electron-updater": "^5.3.0",
        "exifreader": "^4.12.0",
        "ffmpeg-static": "^5.1.0",
        "ffprobe-static": "^3.1.0",
        "fluent-ffmpeg": "^2.1.2",
        "force": "^0.0.3",
        "fs-extra": "^11.1.1",
        "glob": "^10.2.2",
        "heic-decode": "^1.1.2",
        "is-image": "^3.1.0",
        "is-video": "^1.0.1",
        "klaw": "^4.1.0",
        "klaw-sync": "^6.0.0",
        "log4js": "^6.9.1",
        "moment": "^2.29.4",
        "motion": "^10.15.5",
        "pino": "^8.16.0",
        "prebuild-install": "^7.1.1",
        "querystring": "^0.2.1",
        "radash": "^10.8.1",
        "ramda": "^0.29.0",
        "rxjs": "^7.8.1",
        "sharp": "^0.32.1",
        "super-expressive": "^1.4.2"
    },
    "devDependencies": {
        "@ant-design/icons-vue": "^6.1.0",
        "@cloudgeek/vue3-video-player": "^0.3.10",
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@electron/notarize": "^1.2.3",
        "@playwright/test": "^1.52.0",
        "@rollup/plugin-babel": "^6.0.3",
        "@rushstack/eslint-patch": "^1.2.0",
        "@types/fs-extra": "11.0.1",
        "@types/jest": "^29.5.1",
        "@types/klaw": "^3.0.3",
        "@types/node": "16.18.11",
        "@types/pino": "^7.0.5",
        "@types/ramda": "^0.29.1",
        "@types/read-chunk": "^3.1.0",
        "@videojs-player/vue": "^1.0.0",
        "@vitejs/plugin-vue": "^4.2.1",
        "@vue/eslint-config-prettier": "^7.1.0",
        "@vue/eslint-config-typescript": "^11.0.3",
        "@vueuse/components": "^13.2.0",
        "@vueuse/core": "^13.2.0",
        "@vueuse/rxjs": "^13.2.0",
        "ant-design-vue": "^3.2.20",
        "comlink": "^4.4.1",
        "del-cli": "^5.0.0",
        "electron-builder": "^24.13.3",
        "electron-vite": "^3.1.0",
        "eslint": "^9.27.0",
        "eslint-plugin-vue": "9.11.1",
        "image-type": "^5.2.0",
        "jest": "29.5.0",
        "json-tree-view-vue3": "^0.2.3",
        "less": "^4.1.3",
        "memfs": "^3.5.1",
        "mock-fs": "^5.2.0",
        "pinia": "^2.1.6",
        "pinia-plugin-persistedstate": "3.1.0",
        "prettier": "^3.0.3",
        "read-chunk": "^4.0.3",
        "sass": "^1.69.3",
        "ts-jest": "^29.1.1",
        "typescript": "^5.2.2",
        "video.js": "^7.21.5",
        "vite": "^4.5.2",
        "vite-plugin-comlink": "^3.0.2",
        "vite-plugin-esmodule": "^1.5.0",
        "vue": "^3.5.14",
        "vue-concurrency": "^4.0.1",
        "vue-i18n": "9.5.0",
        "vue-tsc": "^1.8.19",
        "webpack": "^5.88.2"
    },
    "volta": {
        "node": "18.18.0",
        "yarn": "1.22.19"
    }
}
