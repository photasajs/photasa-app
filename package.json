{
    "name": "picasa-vue",
    "version": "1.0.0",
    "description": "An Electron application with Vue and TypeScript",
    "main": "./out/main/index.js",
    "author": "example.com",
    "homepage": "https://www.electronjs.org",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
        "start": "electron-vite preview",
        "dev": "electron-vite dev",
        "build": "pnpm typecheck && electron-vite build",
        "postinstall": "electron-builder install-app-deps",
        "build:win": "pnpm build && electron-builder --win --config",
        "build:mac": "pnpm build && electron-builder --mac --config",
        "build:linux": "pnpm build && electron-builder --linux --config",
        "test": "jest --config jest.config.js",
        "coverage": "jest --config jest.config.js --coverage"
    },
    "dependencies": {
        "@ant-design/icons-vue": "^6.1.0",
        "@babel/core": "7.21.0",
        "@bugsnag/js": "7.20.0",
        "@bugsnag/plugin-vue": "7.19.0",
        "@electron-toolkit/preload": "1.0.3",
        "@electron-toolkit/utils": "1.0.2",
        "@types/fs-extra": "11.0.1",
        "chokidar": "3.5.3",
        "electron-updater": "^5.3.0",
        "exifreader": "^4.9.2",
        "fs-extra": "^11.1.0",
        "is-video": "^1.0.1",
        "log4js": "^6.8.0",
        "moment": "^2.29.4",
        "motion": "^10.15.5",
        "pinia": "^2.0.32",
        "pinia-plugin-persistedstate": "3.1.0",
        "querystring": "^0.2.1",
        "radash": "^10.7.0",
        "rxjs": "^7.8.0",
        "sharp": "^0.31.3",
        "super-expressive": "^1.4.2",
        "vue-concurrency": "^4.0.0",
        "vue-i18n": "9.2.2"
    },
    "devDependencies": {
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@electron/notarize": "^1.2.3",
        "@rollup/plugin-babel": "^6.0.3",
        "@rushstack/eslint-patch": "^1.2.0",
        "@types/jest": "^29.4.0",
        "@types/node": "16.18.11",
        "@types/read-chunk": "^3.1.0",
        "@vitejs/plugin-vue": "^4.0.0",
        "@vue/eslint-config-prettier": "^7.0.0",
        "@vue/eslint-config-typescript": "^11.0.2",
        "ant-design-vue": "^3.2.15",
        "electron": "^23.0.0",
        "electron-builder": "^23.6.0",
        "electron-vite": "^1.0.19",
        "eslint": "8.35.0",
        "eslint-plugin-vue": "9.9.0",
        "image-type": "^5.2.0",
        "jest": "29.4.3",
        "klaw": "^4.1.0",
        "less": "^4.1.3",
        "memfs": "^3.4.13",
        "mock-fs": "^5.2.0",
        "prettier": "^2.8.4",
        "read-chunk": "^4.0.3",
        "ts-jest": "^29.0.5",
        "typescript": "^4.9.5",
        "vite": "^4.1.4",
        "vite-plugin-esmodule": "^1.4.4",
        "vue": "^3.2.47",
        "vue-tsc": "^1.2.0",
        "webpack": "^5.75.0"
    },
    "volta": {
        "node": "16.17.0",
        "yarn": "1.22.19"
    }
}
