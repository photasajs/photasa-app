{
    "name": "picasa-vue-monorepo",
    "version": "2.0.0",
    "private": true,
    "scripts": {
        "dev": "pnpm --filter @photasa/photasa run dev",
        "build": "turbo run build",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "prepare": "husky",
        "build:photasa": "pnpm --filter @photasa/photasa run build",
        "build:debug:photasa": "pnpm --filter @photasa/photasa run build:debug",
        "vite:dev:photasa": "pnpm --filter @photasa/photasa run vite:dev",
        "clippy": "cargo clippy --workspace --all-targets -- -D warnings",
        "test:rust": "cargo test --workspace",
        "sync-version": "node scripts/sync-workspace-version.mjs",
        "check-version": "node scripts/sync-workspace-version.mjs --check",
        "generate:release-please": "node scripts/generate-release-please-config.mjs",
        "test:scripts": "node --test scripts/__tests__/*.test.mjs"
    },
    "devDependencies": {
        "@systembug/pangu": "^0.0.12",
        "eslint": "^8.57.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.1.0",
        "prettier": "^3.2.5",
        "turbo": "^2.3.0",
        "typescript": "^7.0.2"
    },
    "packageManager": "pnpm@9.0.0"
}
