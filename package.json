{
    "name": "picasa-vue-monorepo",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "prepare": "husky",
        "dev:desktop": "pnpm --filter @photasa/desktop dev",
        "build:desktop": "pnpm --filter @photasa/desktop build",
        "test:desktop": "pnpm --filter @photasa/desktop test",
        "typecheck:desktop": "pnpm --filter @photasa/desktop typecheck"
    },
    "devDependencies": {
        "turbo": "^2.3.3",
        "husky": "^9.1.7",
        "prettier": "^3.2.5",
        "eslint": "^8.57.0",
        "typescript": "^5.3.3"
    },
    "packageManager": "pnpm@9.0.0"
}
