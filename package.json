{
    "name": "picasa-vue-monorepo",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "pnpm -r run build",
        "test": "pnpm -r run --if-present test",
        "lint": "pnpm -r run --if-present lint",
        "typecheck": "pnpm -r run --if-present typecheck",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "prepare": "husky",
        "validate": "pnpm --filter @photasa/desktop run validate",
        "build:packages": "pnpm -r --filter \"@photasa/desktop^...\" --filter \"!@photasa/desktop\" run build",
        "dev:desktop": "pnpm build:packages && pnpm --filter @photasa/desktop dev",
        "build:desktop": "pnpm build:packages && pnpm --filter @photasa/desktop build",
        "test:desktop": "pnpm --filter @photasa/desktop test",
        "typecheck:desktop": "pnpm --filter @photasa/desktop typecheck",
        "workflow:validate": "pnpm --filter @photasa/desktop run workflow:validate"
    },
    "devDependencies": {
        "eslint": "^8.57.0",
        "husky": "^9.1.7",
        "prettier": "^3.2.5",
        "typescript": "^5.3.3"
    },
    "packageManager": "pnpm@9.0.0"
}
