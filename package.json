{
    "name": "photasa",
    "productName": "Photasa",
    "version": "1.7.0",
    "description": "Another picasa like photo manager",
    "main": "./out/main/index.js",
    "author": "Albert Li <albert_lee@hotmail.com>",
    "homepage": "https://www.photasa.me",
    "scripts": {
        "format": "prettier --write .",
        "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts,.vue --fix",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "npm run typecheck:node && npm run typecheck:web",
        "start": "electron-vite preview",
        "dev": "electron-vite dev",
        "dev:debug": "DEBUG=true electron-vite dev --inspect=9229 --remoteDebuggingPort=9222",
        "build": "npm run typecheck && electron-vite build",
        "build:debug": "npm run typecheck && DEBUG=true electron-vite build",
        "postinstall": "electron-builder install-app-deps && node scripts/install-ffmpeg.js",
        "verify:ffmpeg": "node scripts/verify-ffmpeg.js",
        "build:win": "npm run build && npm run sharp:win && electron-builder --win --config && node scripts/generate-sha512.js",
        "build:mac": "npm run build && electron-builder --mac --config && node scripts/generate-sha512.js",
        "build:linux": "npm run build && electron-builder --linux --config && node scripts/generate-sha512.js",
        "sharp:mac": "del-cli ./node_modules/sharp && npm install --platform=darwin --arch=arm64 sharp --legacy-peer-deps && npm rebuild --platform=darwin --arch=x64 sharp",
        "sharp:win": "del-cli ./node_modules/sharp && npm install --platform=win32 --arch=x64 sharp --legacy-peer-deps",
        "sharp:linux": "del-cli ./node_modules/sharp && npm install --platform=linux --arch=x64 sharp --legacy-peer-deps",
        "test:unit:renderer": "node --max-old-space-size=20480 --max-semi-space-size=4096 ./node_modules/.bin/vitest run --config vitest.config.ts",
        "test:unit:main": "jest --config jest.config.js",
        "test:unit:main:vitest": "node --max-old-space-size=20480 --max-semi-space-size=4096 ./node_modules/.bin/vitest run --config vitest.main.config.ts",
        "test:unit:preload": "node --max-old-space-size=20480 --max-semi-space-size=4096 ./node_modules/.bin/vitest run --config vitest.preload.config.ts",
        "test:unit": "npm run test:unit:renderer && npm run test:unit:main && npm run test:unit:main:vitest && npm run test:unit:preload",
        "test:e2e": "npm run build && playwright test",
        "test:e2e:no-build": "playwright test",
        "test:e2e:headed": "npm run build && playwright test --headed",
        "test:e2e:debug": "npm run build && playwright test --debug",
        "test:e2e:report": "playwright show-report",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch",
        "test": "npm run test:unit",
        "rfc:create": "node scripts/rfc-manager.js create",
        "rfc:list": "node scripts/rfc-manager.js list",
        "rfc:status": "node scripts/rfc-manager.js status",
        "rfc:validate": "node scripts/rfc-manager.js validate",
        "rfc:report": "node scripts/rfc-manager.js report",
        "validate:workflows": "npx tsx scripts/validate-workflows.ts",
        "validate:workflows:fix": "npx tsx scripts/validate-workflows.ts --fix",
        "validate:workflows:verbose": "npx tsx scripts/validate-workflows.ts --verbose",
        "check:locales": "node scripts/check-locales.js",
        "generate:sha512": "node scripts/generate-sha512.js",
        "prepare": "husky"
    },
    "dependencies": {
        "@atlaskit/pragmatic-drag-and-drop": "^1.7.4",
        "@babel/core": "7.21.8",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/utils": "^4.0.0",
        "@headlessui/vue": "^1.7.23",
        "@phosphor-icons/vue": "^2.2.1",
        "@saschazar/wasm-heif": "^2.0.0",
        "@sentry/electron": "^7.0.0",
        "@tanstack/vue-virtual": "^3.13.12",
        "@types/jimp": "^0.2.28",
        "@types/js-yaml": "^4.0.9",
        "@types/uuid": "^10.0.0",
        "ag-psd": "^28.2.2",
        "caf": "^4.0.0",
        "canvas": "^3.2.0",
        "chokidar": "3.5.3",
        "comlink": "^4.4.1",
        "concurrent-tasks": "^1.0.7",
        "dayjs": "^1.11.18",
        "electron-is-dev": "^2.0.0",
        "electron-updater": "^6.6.2",
        "exifreader": "^4.12.0",
        "ffmpeg-static": "^5.2.0",
        "ffprobe-static": "^3.1.0",
        "file-type": "^21.0.0",
        "fluent-ffmpeg": "^2.1.2",
        "fp-ts": "^2.16.10",
        "fs-extra": "^11.1.1",
        "glob": "^11.0.3",
        "graceful-fs": "^4.2.11",
        "heic-decode": "^2.1.0",
        "is-image": "^3.1.0",
        "is-video": "^1.0.1",
        "jimp": "^1.6.0",
        "js-yaml": "^4.1.0",
        "klaw": "^4.1.0",
        "klaw-sync": "^6.0.0",
        "log4js": "^6.9.1",
        "moment": "^2.29.4",
        "motion": "^10.15.5",
        "node-abi": "^4.14.0",
        "p-queue": "^8.1.0",
        "photoswipe": "^5.4.4",
        "pino": "^8.16.0",
        "prebuild-install": "^7.1.1",
        "querystring": "^0.2.1",
        "radash": "^10.8.1",
        "ramda": "^0.29.0",
        "rxjs": "^7.8.1",
        "sharp": "^0.34.4",
        "stream-json": "^1.9.1",
        "super-expressive": "^1.4.2",
        "tailwindcss": "^3.4.17",
        "uuid": "^11.1.0",
        "vue3-markdown-it": "^1.0.10"
    },
    "devDependencies": {
        "@cloudgeek/vue3-video-player": "^0.3.10",
        "@electron-toolkit/tsconfig": "^1.0.1",
        "@electron/notarize": "^1.2.3",
        "@playwright/test": "^1.52.0",
        "@rollup/plugin-babel": "^6.0.3",
        "@rollup/plugin-yaml": "^4.1.2",
        "@rushstack/eslint-patch": "^1.2.0",
        "@testing-library/vue": "^8.1.0",
        "@types/file-type": "^10.6.0",
        "@types/fs-extra": "11.0.1",
        "@types/jest": "^30.0.0",
        "@types/klaw": "^3.0.3",
        "@types/node": "^18.19.115",
        "@types/pino": "^7.0.5",
        "@types/ramda": "^0.29.1",
        "@types/read-chunk": "^3.1.0",
        "@videojs-player/vue": "^1.0.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitejs/plugin-vue-jsx": "^5.0.1",
        "@vitest/coverage-v8": "^3.1.4",
        "@vue/eslint-config-prettier": "^9.0.0",
        "@vue/eslint-config-typescript": "^11.0.3",
        "@vue/runtime-dom": "^3.5.17",
        "@vue/test-utils": "^2.4.6",
        "@vueuse/components": "^13.2.0",
        "@vueuse/core": "^13.2.0",
        "@vueuse/rxjs": "^13.2.0",
        "autoprefixer": "^10.4.16",
        "boxen": "^8.0.1",
        "chalk": "^5.6.2",
        "cli-table3": "^0.6.5",
        "comlink": "^4.4.1",
        "commander": "^14.0.1",
        "del-cli": "^6.0.0",
        "electron": "^38.1.0",
        "electron-builder": "^26.0.20",
        "electron-vite": "^3.1.0",
        "eslint": "^8.0.0",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-vue": "9.11.1",
        "happy-dom": "^17.5.6",
        "husky": "^9.1.7",
        "image-type": "^5.2.0",
        "jest": "^29.7.0",
        "jsdom": "^23.2.0",
        "json-tree-view-vue3": "^0.2.3",
        "less": "^4.1.3",
        "memfs": "^3.5.1",
        "mock-fs": "^5.2.0",
        "ora": "^9.0.0",
        "pinia": "^2.1.6",
        "pinia-plugin-persistedstate": "3.1.0",
        "postcss": "^8.5.6",
        "prettier": "^3.2.5",
        "read-chunk": "^4.0.3",
        "sass": "^1.69.3",
        "ts-jest": "^29.4.4",
        "typescript": "^5.9.2",
        "video.js": "^7.21.5",
        "vite": "^6.3.5",
        "vite-plugin-comlink": "^5.3.0",
        "vite-plugin-esmodule": "^1.5.0",
        "vite-svg-loader": "^5.1.0",
        "vitest": "^3.2.4",
        "vue": "^3.5.14",
        "vue-concurrency": "^5.0.3",
        "vue-i18n": "^9.14.4",
        "vue-tsc": "^3.0.6",
        "webpack": "^5.88.2"
    },
    "volta": {
        "node": "23.11.0",
        "yarn": "1.22.19"
    }
}
