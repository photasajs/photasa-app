# PostHog analytics (Vite build-time variables)
#
# These are read by Vite at build time (vite build / tauri build) and inlined
# into the renderer bundle as import.meta.env.VITE_*. They are NOT available
# at runtime, so they must be present in the environment when the production
# bundle is built.
#
# Copy this file to .env (which is gitignored) and fill in real values, or set
# the same names as environment variables / GitHub Actions secrets in CI.
#
# Required for production telemetry. When VITE_POSTHOG_PROJECT_TOKEN is unset,
# PostHog initialization is skipped (no-op in production; loud console error in DEV).
VITE_POSTHOG_PROJECT_TOKEN=your_posthog_project_token_here
VITE_POSTHOG_HOST=https://us.i.posthog.com
