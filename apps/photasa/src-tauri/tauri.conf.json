{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Photasa",
    "version": "0.1.0",
    "identifier": "me.photasa.app",
    "build": {
        "beforeDevCommand": "pnpm run vite:dev",
        "beforeBuildCommand": "pnpm run vite:build",
        "devUrl": "http://localhost:1421",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "resizable": true,
                "title": "Photasa",
                "titleBarStyle": "Transparent",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "visible": false
            },
            {
                "label": "splash",
                "title": "Photasa",
                "url": "splash.html",
                "width": 420,
                "height": 260,
                "resizable": false,
                "decorations": false,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "minimizable": false,
                "maximizable": false,
                "closable": false,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": {
                "default-src": "'self' ipc: ipc://* http://ipc.localhost asset: asset://localhost http://asset.localhost https://asset.localhost",
                "script-src": "'self' 'unsafe-eval' http://localhost:1421",
                "style-src": "'self' 'unsafe-inline' http://localhost:1421",
                "img-src": "'self' asset: asset://localhost http://asset.localhost https://asset.localhost blob: data:",
                "media-src": "'self' asset: asset://localhost http://asset.localhost https://asset.localhost blob: data:",
                "connect-src": "ipc: ipc://* ipc://localhost http://ipc.localhost http://localhost:1421 ws://localhost:1421"
            },
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "requireLiteralLeadingDot": false,
                    "allow": [
                        "$HOME/**",
                        "$PICTURE/**",
                        "$DOCUMENT/**",
                        "$DOWNLOAD/**",
                        "$DESKTOP/**",
                        "/Volumes/**",
                        "**"
                    ]
                }
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": []
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "fs": {
            "requireLiteralLeadingDot": false
        },
        "updater": {
            "pubkey": "",
            "endpoints": []
        }
    }
}
