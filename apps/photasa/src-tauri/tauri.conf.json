{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Photasa",
    "version": "0.1.0",
    "identifier": "me.photasa.app",
    "build": {
        "beforeDevCommand": "pnpm run dev:web",
        "beforeBuildCommand": "",
        "devUrl": "http://localhost:1421",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "fullscreen": false,
                "resizable": true,
                "title": "Photasa",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.png"],
        "resources": []
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "fs": {
            "requireLiteralLeadingDot": false
        },
        "updater": {
            "pubkey": "",
            "endpoints": []
        }
    }
}
