{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Photasa",
    "version": "0.1.0",
    "identifier": "me.photasa.app",
    "build": {
        "beforeDevCommand": "pnpm run vite:dev",
        "beforeBuildCommand": "pnpm run vite:build",
        "devUrl": "http://localhost:1421",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "resizable": true,
                "title": "Photasa",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "visible": false
            },
            {
                "label": "splash",
                "title": "Photasa",
                "url": "splash.html",
                "width": 420,
                "height": 260,
                "resizable": false,
                "decorations": false,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "visible": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["app"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "resources": []
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "fs": {
            "requireLiteralLeadingDot": false
        },
        "updater": {
            "pubkey": "",
            "endpoints": []
        }
    }
}
