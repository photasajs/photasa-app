{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Photasa Dev",
    "identifier": "me.photasa.app.dev",
    "app": {
        "windows": [
            {
                "label": "main",
                "fullscreen": false,
                "resizable": true,
                "title": "Photasa (Dev)",
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "decorations": true,
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "visible": false
            },
            {
                "label": "splash",
                "title": "Photasa (Dev)",
                "url": "splash.html",
                "width": 420,
                "height": 260,
                "resizable": false,
                "decorations": false,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "minimizable": false,
                "maximizable": false,
                "closable": false,
                "visible": true,
                "center": true
            }
        ]
    },
    "plugins": {
        "updater": {
            "endpoints": []
        }
    }
}
