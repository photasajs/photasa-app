{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": [
        "electron.vite.config.*",
        "src/common/*",
        "src/main/**/*",
        "src/preload/*",
        "src/shared/*",
    ],
    "exclude": [
        "src/**/*.spec.ts",
        "src/**/*.test.ts",
        "src/**/__tests__/**/*",
    ],
    "compilerOptions": {
        "composite": true,
        "types": [
            "electron-vite/node",
            "jest"
        ],
        "esModuleInterop": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "@main/*": ["./src/main/*"],
            "@preload/*": ["./src/preload/*"],
            "@shared/*": ["./src/shared/*"],
            "@engines/*": ["./src/main/engines/*"],
            "@engines/common/*": ["./src/main/engines/common/*"],
            "@tianshu/*": ["./src/main/engines/tianshu/*"],
            "@photasa/common/*": ["../../packages/@photasa/common/src/*"],
            "@photasa/tianshu": ["../../packages/@photasa/tianshu/src/index.ts"],
            "@photasa/tianshu/*": ["../../packages/@photasa/tianshu/src/*"],
            "@photasa/wenchang": ["../../packages/@photasa/wenchang/src/index.ts"],
            "@photasa/wenchang/*": ["../../packages/@photasa/wenchang/src/*"],
            "@photasa/sibu": ["../../packages/@photasa/sibu/src/index.ts"],
            "@photasa/ffmpeg": ["../../packages/@photasa/ffmpeg/src/index.ts"],
            "@photasa/sibu/*": ["../../packages/@photasa/sibu/src/*"],
            "@photasa/qianliyan": ["../../packages/@photasa/qianliyan/src/index.ts"],
            "@photasa/qianliyan/*": ["../../packages/@photasa/qianliyan/src/*"],
            "@photasa/shunfenger": ["../../packages/@photasa/shunfenger/src/index.ts"],
            "@photasa/shunfenger/*": ["../../packages/@photasa/shunfenger/src/*"]
        },
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    }
}
