{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Photasa: Tauri dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "console": "integratedTerminal"
    },
    {
      "name": "Photasa: Debug Rust tests",
      "type": "lldb",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/photasa/src-tauri",
      "cargo": {
        "args": ["test", "--no-run"],
        "filter": {
          "name": "photasa",
          "kind": "lib"
        }
      },
      "args": [],
      "sourceLanguages": ["rust"]
    }
  ]
}
