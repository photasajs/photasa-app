{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": [
        "electron.vite.config.*",
        "src/common/*",
        "src/main/**/*",
        "src/preload/*",
        "src/shared/*",
        "src/engines/**/*",
    ],
    "exclude": [
        "src/**/*.spec.ts",
        "src/**/*.test.ts",
        "src/**/__tests__/**/*",
    ],
    "compilerOptions": {
        "composite": true,
        "types": [
            "electron-vite/node"
        ],
        "esModuleInterop": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "@main/*": ["./src/main/*"],
            "@common/*": ["./src/common/*"],
            "@preload/*": ["./src/preload/*"],
            "@shared/*": ["./src/shared/*"],
            "@maliang/*": ["./src/engines/maliang/*"],
            "@shunfenger/*": ["./src/engines/shunfenger/*"],
            "@sibu": ["./src/engines/sibu/index"],
            "@sibu/*": ["./src/engines/sibu/*"],
            "@tianshu": ["./src/engines/tianshu/index"],
            "@tianshu/*": ["./src/engines/tianshu/*"],
            "@engines/common/*": ["./src/engines/common/*"],
            "@qianliyan/*": ["./src/engines/qianliyan/*"],
            "@engines/*": ["./src/engines/*"],
        },
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true
    }
}
