{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": [
        "electron.vite.config.*",
        "src/common/*",
        "src/main/**/*",
        "src/preload/*",
    ],
    "compilerOptions": {
        "composite": true,
        "types": [
            "electron-vite/node"
        ],
        "esModuleInterop": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "@common/*": ["./src/common/*"],
            "@preload/*": ["./src/preload/*"],
            "@renderer/*": ["./src/renderer/src/*"]
        }
    }
}
