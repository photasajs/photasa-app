{
    "name": "@photasa/sibu",
    "version": "2.0.0",
    "description": "Sibu Engine - Configuration Management for Photasa",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@types/stream-chain": "^2.1.0",
        "@types/stream-json": "^1.7.8",
        "@types/uuid": "^10.0.0",
        "fs-extra": "^11.1.1",
        "js-yaml": "^4.1.0",
        "stream-chain": "^3.4.0",
        "stream-json": "^1.9.1",
        "uuid": "^11.1.0",
        "zod": "^3.21.4"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.1",
        "@types/js-yaml": "^4.0.5",
        "@types/node": "^18.16.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^8.39.0",
        "typescript": "^5.0.4",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.0.0",
        "vitest": "^1.0.0"
    }
}
