{
    "name": "@photasa/shunfenger",
    "version": "2.0.0",
    "description": "Shunfenger File Watching Engine",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "keywords": [
        "watch",
        "engine",
        "shunfenger",
        "file-watching"
    ],
    "author": "SystemBug",
    "license": "MIT",
    "dependencies": {
        "@photasa/common": "workspace:*",
        "chokidar": "^3.6.0",
        "events": "^1.0.0",
        "fs-extra": "^11.1.1"
    },
    "devDependencies": {
        "vite": "^8.1.5",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^1.6.0",
        "typescript": "^7.0.2",
        "@types/node": "^26.1.1",
        "@types/fs-extra": "^11.0.1",
        "@types/chokidar": "^2.1.3"
    }
}
