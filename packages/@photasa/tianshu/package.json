{
    "name": "@photasa/tianshu",
    "version": "1.0.0",
    "description": "Tianshu Workflow Runtime Engine",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "keywords": [
        "workflow",
        "runtime",
        "engine",
        "tianshu"
    ],
    "author": "SystemBug",
    "license": "MIT",
    "dependencies": {
        "@zouwu-wf/workflow": "^0.0.7",
