{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/*"],
            "@main/scan/*": ["src/*"],
            "@shared/path-util": ["src/utils/path-utils"]
        },
        "types": ["node", "vite/client", "vitest/globals"]
    },
    "include": ["src/**/*.ts", "vite.config.ts", "vitest.config.ts"],
    "exclude": ["node_modules", "dist"]
}
