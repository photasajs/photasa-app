{
    "name": "@photasa/scan",
    "version": "0.0.1",
    "description": "Scan - Photo scanning, strategy, and cache management",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "jest --config jest.config.js && vitest run",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@photasa/config-core": "workspace:*",
        "fs-extra": "^11.1.1",
        "is-image": "^3.1.0",
        "is-video": "^1.0.1",
        "klaw": "^4.1.0",
        "rxjs": "^7.8.1"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@types/fs-extra": "^11.0.1",
        "@types/klaw": "^3.0.6",
        "@types/node": "^18.16.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^8.39.0",
        "jest": "^30.4.2",
        "ts-jest": "^29.4.4",
        "rimraf": "^5.0.0",
        "typescript": "^5.0.4",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.0.0",
        "vitest": "^1.0.0"
    }
}
