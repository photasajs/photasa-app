{
    "name": "@photasa/thumbnail",
    "version": "2.0.0",
    "description": "Thumbnail - Pure Node.js thumbnail generation logic",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "jest --config jest.config.js && vitest run",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@photasa/config-core": "workspace:*",
        "@photasa/maliang": "workspace:*",
        "fs-extra": "^11.1.1",
        "is-image": "^3.1.0",
        "is-video": "^1.0.1"
    },
    "devDependencies": {
        "@jest/globals": "^30.2.0",
        "@types/fs-extra": "^11.0.1",
        "@types/node": "^26.1.1",
        "@vitejs/plugin-vue": "^6.0.8",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^8.39.0",
        "jest": "^29.7.0",
        "log4js": "^6.9.1",
        "sharp": "^0.34.4",
        "ts-jest": "^29.4.4",
        "rimraf": "^5.0.0",
        "typescript": "^7.0.2",
        "vite": "^8.1.5",
        "vite-plugin-dts": "^5.0.3",
        "vitest": "^1.0.0"
    }
}
