{
    "name": "@photasa/maliang",
    "version": "1.0.0",
    "description": "Photasa painting engine",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js",
            "import": "./dist/index.mjs"
        }
    },
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts,.tsx --fix",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@photasa/maliang-bundle": "workspace:*",
        "exifreader": "^4.12.0",
        "fs-extra": "^11.1.1",
        "jimp": "^0.22.10",
        "sharp": "^0.34.4",
        "uuid": "^11.1.0"
    },
    "devDependencies": {
        "@types/fs-extra": "11.0.1",
        "@types/node": "^18.19.115",
        "@types/pixelmatch": "^5.2.6",
        "@types/pngjs": "^6.0.5",
        "@vitejs/plugin-vue": "^5.0.0",
        "pixelmatch": "^7.1.0",
        "pngjs": "^7.0.0",
        "typescript": "^5.9.2",
        "vite": "^6.3.5",
        "vite-plugin-dts": "^3.9.1",
        "vitest": "^4.0.16"
    }
}
