{
    "name": "@photasa/siming",
    "version": "1.7.0",
    "description": "Siming Engine - AppState Persistence Engine",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@photasa/taiyi": "workspace:*",
        "fs-extra": "^11.1.1",
        "inversify": "^6.0.1",
        "reflect-metadata": "^0.1.13"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.1",
        "@types/node": "^18.16.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^8.39.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.0.4",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.0.0",
        "vitest": "^1.0.0"
    }
}
