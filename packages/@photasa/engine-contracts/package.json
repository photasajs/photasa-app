{
    "name": "@photasa/engine-contracts",
    "version": "1.0.0",
    "description": "Cross-engine collaboration contracts for Photasa",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "vite build",
        "watch": "vite build --watch",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "keywords": [
        "contracts",
        "engines",
        "photasa"
    ],
    "author": "SystemBug",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.11.24",
        "typescript": "^5.3.3",
        "vite": "^5.4.2",
        "vite-plugin-dts": "^3.9.1",
        "vitest": "^1.6.0"
    }
}
