{
    "name": "@photasa/import",
    "version": "2.1.0",
    "description": "Import - Photo import logic, metadata extraction, file grouping and deduplication",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build",
        "dev": "vite build --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "@photasa/common": "workspace:*",
        "@photasa/maliang": "workspace:*",
        "ag-psd": "^28.2.2",
        "exifreader": "^4.12.0",
        "fluent-ffmpeg": "^2.1.2",
        "fs-extra": "^11.1.1"
    },
    "devDependencies": {
        "@types/fluent-ffmpeg": "^2.1.21",
        "@types/fs-extra": "^11.0.1",
        "@types/node": "^18.16.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vitest/coverage-v8": "^1.0.0",
        "eslint": "^8.39.0",
        "rimraf": "^5.0.0",
        "typescript": "^5.0.4",
        "vite": "^5.0.0",
        "vite-plugin-dts": "^3.0.0",
        "vitest": "^1.0.0"
    }
}
