{
    "apps/photasa/src/locales/**/*.json": [
        "prettier --write",
        "pnpm --filter @photasa/photasa run check:locales"
    ],
    "apps/photasa/src/**/*.{ts,tsx,vue}": [
        "prettier --write",
        "eslint --fix --quiet --cache --cache-location apps/photasa/node_modules/.cache/eslint/lint-staged --no-eslintrc -c apps/photasa/.eslintrc.cjs",
        "pnpm --filter @photasa/photasa run check:locales"
    ],
    "apps/photasa/src/**/*.{js,cjs,mjs}": [
        "prettier --write",
        "eslint --fix --quiet --cache --cache-location apps/photasa/node_modules/.cache/eslint/lint-staged --no-eslintrc -c apps/photasa/.eslintrc.cjs"
    ],
    "apps/photasa/*.{ts,js,mjs,cjs}": [
        "prettier --write",
        "eslint --fix --quiet --cache --cache-location apps/photasa/node_modules/.cache/eslint/lint-staged --no-eslintrc -c apps/photasa/.eslintrc.cjs"
    ],
    "packages/**/*.{ts,tsx}": ["prettier --write"],
    "**/*.{json,md,yaml,yml}": ["prettier --write"]
}
